{
  "name": "autoxpress-pricing-intelligence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "build": "prisma generate && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc -p tsconfig.server.json && vite build && npx playwright install chromium",
    "preview": "vite preview",
    "start": "node dist-server/server/index.js",
    "start:server": "node dist-server/server/index.js",
    "start:web": "node scripts/start-web.mjs",
    "start:worker": "node dist-server/server/worker.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.46.1",
    "connect-redis": "^8.0.2",
    "cors": "^2.8.6",
    "csv-parse": "^5.6.0",
    "express": "^4.22.1",
    "express-session": "^1.18.1",
    "ioredis": "^5.4.2",
    "playwright": "^1.58.2",
    "prisma": "^6.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.8.0",
    "redis": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
}
